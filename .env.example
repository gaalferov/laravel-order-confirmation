APP_NAME="Order Confirmation"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

MAIL_MAILER=mailtrap-sdk
MAILTRAP_HOST=send.api.mailtrap.io
MAILTRAP_API_KEY=your_mailtrap_api_key
MAILTRAP_TEMPLATE_UUID=your_order_confirmation_template_uuid
# Set MAILTRAP_SANDBOX=true plus MAILTRAP_INBOX_ID to capture mail in a sandbox inbox during testing
MAILTRAP_SANDBOX=false
# MAILTRAP_INBOX_ID=
MAIL_FROM_ADDRESS=orders@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"
# Fallback recipient when Stripe session has no customer email (e.g. `stripe trigger` events)
MAIL_ORDER_RECIPIENT=customer@example.com

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

CACHE_STORE=file
